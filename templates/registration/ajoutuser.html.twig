{# templates/registration/ajoutuser.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Inscription - Khadamni{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="card shadow mx-auto" style="max-width: 600px;">
        <div class="card-header bg-primary text-white text-center">
            <h3>Créer un compte</h3>
        </div>
        <div class="card-body">
            {{ form_start(formAjout, {'attr': {'novalidate': 'novalidate'}}) }}
                {# 'novalidate' permet de laisser Symfony gérer les erreurs plutôt que le navigateur #}

                <div class="row mb-3">
                    <div class="col">
                        {{ form_label(formAjout.nom) }}
                        {{ form_widget(formAjout.nom) }}
                        <div class="text-danger">{{ form_errors(formAjout.nom) }}</div>
                    </div>
                    <div class="col">
                        {{ form_label(formAjout.prenom) }}
                        {{ form_widget(formAjout.prenom) }}
                        <div class="text-danger">{{ form_errors(formAjout.prenom) }}</div>
                    </div>
                </div>

                <div class="mb-3">
                    {{ form_label(formAjout.email) }}
                    {{ form_widget(formAjout.email) }}
                    <div class="text-danger">{{ form_errors(formAjout.email) }}</div>
                </div>

                <div class="mb-3">
                    {{ form_label(formAjout.password) }}
                    {{ form_widget(formAjout.password) }}
                    <div class="text-danger">{{ form_errors(formAjout.password) }}</div>
                </div>

                <div class="mb-3">
                    {{ form_label(formAjout.type) }}
                    {{ form_widget(formAjout.type) }}
                </div>

                <button type="submit" class="btn btn-success w-100 mt-3">S'inscrire</button>
            {{ form_end(formAjout) }}
        </div>
        <div class="card-footer text-center">
            <p>Déjà inscrit ? <a href="{{ path('app_login') }}">Connectez-vous</a></p>
        </div>
    </div>
</div>
{% endblock %}